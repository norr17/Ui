        local function CloseDropdown()
            if dropFrame then
                dropFrame:Destroy()
                dropFrame = nil
            end
            open = false
            arrowLabel.Text = "▾"
        end

        local function OpenDropdown()
            if dropFrame then CloseDropdown(); return end
            open = true
            arrowLabel.Text = "▴"

            dropFrame = New("Frame", {
                Name = "Dropdown",
                Size = UDim2.new(0, 140, 0, math.min(#values, 8) * 24 + 4),
                Position = UDim2.new(1, -140, 1, 2),
