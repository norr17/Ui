-- 21. WATERMARK CONTROL
-- ════════════════════════════════════════════════════════════════════════════
function Library:SetWatermarkVisible(visible)
    if self._window and self._window._frame then
        local titlebar = self._window._frame:FindFirstChild("Titlebar") -- won't work directly
    end
    -- The watermark is part of the titlebar; access via ScreenGui
    if self.ScreenGui then
        local w = self.ScreenGui:FindFirstChild("Window", true)
        if w then
            local tb = w:FindFirstChild("Titlebar")
            if tb then
                local wm = tb:FindFirstChild("Watermark")
                if wm then wm.Visible = visible end
            end
        end
    end
end

function Library:SetWatermark(text)
    if self.ScreenGui then
        local w = self.ScreenGui:FindFirstChild("Window", true)
        if w then
            local tb = w:FindFirstChild("Titlebar")
            if tb then
                local wm = tb:FindFirstChild("Watermark")
                if wm then wm.Text = text end
            end
        end
    end
end

-- ════════════════════════════════════════════════════════════════════════════
-- 22. MOBILE SUPPORT
-- ════════════════════════════════════════════════════════════════════════════
Library.IsMobile = UserInputService.TouchEnabled and not UserInputService.MouseEnabled

if Library.IsMobile then
    -- Create a floating toggle button for mobile
    function Library:CreateMobileButton()
        if not self.ScreenGui then return end
        local btn = New("TextButton", {
            Text = "K",
            Font = Enum.Font.GothamBold,
            TextSize = 14,
            TextColor3 = Color3.fromRGB(255,255,255),
            BackgroundColor3 = self.Scheme.AccentColor,
            Size = UDim2.fromOffset(44, 44),
            Position = UDim2.new(0, 10, 0.5, -22),
            ZIndex = 80,
            Parent = self.ScreenGui,
        })
        MakeCorner(22, btn)
        btn.MouseButton1Click:Connect(function()
            self:Toggle()
        end)
        -- Drag support
        local dragging, dragOffset = false, Vector2.new()
        btn.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
                dragging = true
                dragOffset = Vector2.new(input.Position.X - btn.AbsolutePosition.X, input.Position.Y - btn.AbsolutePosition.Y)
            end
        end)
        self:Connect(UserInputService.InputChanged, function(input)
            if dragging and (input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseMovement) then
                local cam = workspace.CurrentCamera.ViewportSize
                local nx = math.clamp(input.Position.X - dragOffset.X, 0, cam.X - 44)
                local ny = math.clamp(input.Position.Y - dragOffset.Y, 0, cam.Y - 44)
                btn.Position = UDim2.fromOffset(nx, ny)
            end
        end)
        self:Connect(UserInputService.InputEnded, function(input)
            if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
                dragging = false
            end
        end)
    end
end

