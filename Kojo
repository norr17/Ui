            MakePadding(2, 0, 2, 0, dropFrame)
            MakeList(Enum.FillDirection.Vertical, 0, dropFrame)

            for _, v in ipairs(values) do
                local isSelected = (v == selected)
                local item = New("TextButton", {
                    Text = "",
                    AutoButtonColor = false,
                    Size = UDim2.new(1, 0, 0, 24),
                    BackgroundColor3 = isSelected and lib.Scheme.AccentColor:Lerp(Color3.fromRGB(0,0,0), 0.8) or Color3.fromRGB(0,0,0),
                    BackgroundTransparency = isSelected and 0 or 1,
                    ZIndex = 101,
                    Parent = dropFrame,
                })
                New("TextLabel", {
                    Text = tostring(v),
                    Font = Enum.Font.Gotham,
                    TextSize = 11,
                    TextColor3 = isSelected and lib.Scheme.AccentColor or Color3.fromRGB(70, 67, 95),
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, -20, 1, 0),
                    Position = UDim2.fromOffset(10, 0),
