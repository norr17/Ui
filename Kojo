-- 11. UNLOAD
-- ════════════════════════════════════════════════════════════════════════════
function Library:Unload()
    self.Unloaded = true

    -- Disconnect all connections
    for _, conn in ipairs(self.Connections) do
        pcall(function() conn:Disconnect() end)
    end
    self.Connections = {}

    -- Call all unload functions
    for _, fn in ipairs(self.UnloadFuncs) do
        pcall(fn)
    end
    self.UnloadFuncs = {}

    -- Destroy GUI
    if self.ScreenGui then
        pcall(function() self.ScreenGui:Destroy() end)
        self.ScreenGui = nil
    end

    -- Clear tables
    self.Toggles = {}
    self.Options  = {}
    self.Registry = {}
    self.Toggled  = false

    self:Notify("Library unloaded", 3, "info")
end

