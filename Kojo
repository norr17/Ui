    function gbObj:AddColorPicker(id, opts)
        opts = opts or {}
        local title    = opts.Title    or opts.Text or id
        local default  = opts.Default  or Color3.fromRGB(255,255,255)
        local callback = opts.Callback or function() end
        local disabled = opts.Disabled or false

        local val    = default
        local transp = opts.Transparency or 0
        local lib    = self._lib

