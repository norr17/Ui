-- 2. COLOUR REGISTRY (for live theme changes)
-- ════════════════════════════════════════════════════════════════════════════
-- Registry entry = { Instance, Property, SchemeKey, Modifier? }
-- Modifier: function(baseColor) -> Color3

function Library:RegisterColor(instance, property, schemeKey, modifier)
    if not instance or not property then return end
    table.insert(self.Registry, { Instance=instance, Property=property, Key=schemeKey, Mod=modifier })
    -- Apply immediately
    local base = self.Scheme[schemeKey] or Color3.new(1,1,1)
    instance[property] = modifier and modifier(base) or base
end

function Library:UpdateColorsUsingRegistry()
    for _, entry in ipairs(self.Registry) do
        local ok, base = pcall(function() return self.Scheme[entry.Key] or Color3.new(1,1,1) end)
        if ok and entry.Instance and entry.Instance.Parent then
            local color = entry.Mod and entry.Mod(base) or base
            local ok2 = pcall(function() entry.Instance[entry.Property] = color end)
            if not ok2 then end
        end
    end
end

function Library:SetFont(font)
    self.Scheme.Font = typeof(font) == "EnumItem" and Font.fromEnum(font) or font
    self:UpdateColorsUsingRegistry()
end

