-- 20. SEARCH BAR (global search across groupboxes)
-- ════════════════════════════════════════════════════════════════════════════
-- Can be added to Settings tab
function Library:AddSearchBox(groupbox)
    local searchInput = groupbox:AddInput("GlobalSearch", {
        Text = "Search",
        Placeholder = "Search features...",
        Callback = function(query)
            self.SearchText = query:lower()
            self.Searching  = query ~= ""
            -- TODO: iterate visible groupboxes and filter rows
        end,
    })
    return searchInput
end

