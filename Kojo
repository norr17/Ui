-- 6. LOADING SCREEN
-- ════════════════════════════════════════════════════════════════════════════
local LoadingData = nil

function Library:SetLoadingScreen(opts)
    LoadingData = {
        Title    = opts.Title    or "Kojo Hub",
        Subtitle = opts.Subtitle or "Loading...",
        Logo     = opts.Logo     or "",
        Steps    = opts.Steps    or { "Initializing...", "Loading settings...", "Preparing UI...", "Ready!" },
        Color    = opts.Color    or self.Scheme.AccentColor,
    }
end

local function ShowLoadingScreen(data)
    local accent = data.Color
    local container = GetGuiContainer()

    local sg = New("ScreenGui", {
        Name = "KojoLoading",
        ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
        IgnoreGuiInset = true,
        DisplayOrder = 100,
        Parent = container,
    })
    protectgui(sg)

    -- Background
    local bg = New("Frame", {
        Size = UDim2.fromScale(1, 1),
        BackgroundColor3 = Color3.fromRGB(4, 3, 10),
        ZIndex = 1,
        Parent = sg,
    })

    -- Center card
    local card = New("Frame", {
        Size = UDim2.fromOffset(380, 240),
        Position = UDim2.fromScale(0.5, 0.5),
        AnchorPoint = Vector2.new(0.5, 0.5),
        BackgroundColor3 = Color3.fromRGB(8, 7, 16),
        ZIndex = 2,
        Parent = bg,
    })
    MakeCorner(12, card)
    MakeStroke(Color3.fromRGB(20,18,32), 1, card)

    -- Logo area
    local logoFrame = New("Frame", {
        Size = UDim2.fromOffset(56, 56),
        Position = UDim2.new(0.5, -28, 0, 28),
        BackgroundTransparency = 1,
        ZIndex = 3,
        Parent = card,
    })

    if data.Logo ~= "" then
        New("ImageLabel", {
            Size = UDim2.fromScale(1, 1),
            BackgroundTransparency = 1,
            Image = data.Logo,
            ZIndex = 4,
            Parent = logoFrame,
        })
    end

    -- Spinner ring (ImageLabel rotating)
    local spinnerRing = New("Frame", {
        Size = UDim2.fromScale(1, 1),
        BackgroundTransparency = 1,
        ZIndex = 5,
        Parent = logoFrame,
    })
    local spinnerLine = New("Frame", {
        Size = UDim2.fromOffset(4, 20),
        Position = UDim2.new(0.5, -2, 0, 0),
        BackgroundColor3 = accent,
        ZIndex = 6,
        Parent = spinnerRing,
    })
    MakeCorner(2, spinnerLine)

    -- Title
    local titleLabel = New("TextLabel", {
        Text = data.Title,
        Font = Enum.Font.GothamBold,
        TextSize = 18,
        TextColor3 = Color3.fromRGB(255, 255, 255),
        BackgroundTransparency = 1,
        Size = UDim2.new(1, -32, 0, 24),
        Position = UDim2.fromOffset(16, 96),
        TextXAlignment = Enum.TextXAlignment.Center,
        ZIndex = 3,
        Parent = card,
    })

    -- Status text
    local statusLabel = New("TextLabel", {
        Text = data.Steps[1],
        Font = Enum.Font.Gotham,
        TextSize = 11,
        TextColor3 = Color3.fromRGB(90, 85, 120),
        BackgroundTransparency = 1,
        Size = UDim2.new(1, -32, 0, 16),
        Position = UDim2.fromOffset(16, 126),
        TextXAlignment = Enum.TextXAlignment.Center,
        ZIndex = 3,
        Parent = card,
    })

    -- Progress bar track
    local progressTrack = New("Frame", {
        Size = UDim2.new(1, -48, 0, 3),
        Position = UDim2.fromOffset(24, 158),
        BackgroundColor3 = Color3.fromRGB(16, 15, 26),
        ZIndex = 3,
        Parent = card,
    })
    MakeCorner(2, progressTrack)
    local progressFill = New("Frame", {
        Size = UDim2.fromOffset(0, 3),
        BackgroundColor3 = accent,
        ZIndex = 4,
        Parent = progressTrack,
    })
    MakeCorner(2, progressFill)

    -- Version / footer
    New("TextLabel", {
        Text = "Please wait...",
        Font = Enum.Font.Gotham,
        TextSize = 10,
        TextColor3 = Color3.fromRGB(40, 38, 55),
        BackgroundTransparency = 1,
        Size = UDim2.new(1, -32, 0, 14),
        Position = UDim2.fromOffset(16, 174),
        TextXAlignment = Enum.TextXAlignment.Center,
        ZIndex = 3,
        Parent = card,
    })

    -- Animate spinner
    local angle = 0
    local spinConn = RunService.RenderStepped:Connect(function(dt)
        angle = (angle + dt * 280) % 360
        spinnerRing.Rotation = angle
    end)

    local stepCount  = #data.Steps
    local trackWidth = progressTrack.AbsoluteSize.X - 0

    -- Animate progress
    task.spawn(function()
        local delay = 0.75
        for i, step in ipairs(data.Steps) do
            task.wait(delay)
            if not sg.Parent then break end
            statusLabel.Text = step
            Tween(progressFill, FAST_TWEEN, {
                Size = UDim2.fromScale(i / stepCount, 1)
            })
        end
        task.wait(0.5)
        spinConn:Disconnect()
        -- Fade out
        Tween(bg, MED_TWEEN, { BackgroundTransparency = 1 })
        Tween(card, MED_TWEEN, { BackgroundTransparency = 1 })
        task.wait(0.3)
        sg:Destroy()
    end)
end

