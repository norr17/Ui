        local kpObj = { Value=currentKey, Mode=mode, Modifiers={}, Type="KeyPicker", Id=id }

        local function StartListening()
            if disabled then return end
            listening = true
            keyBtn.Text = "..."
            keyBtn.TextColor3 = lib.Scheme.AccentColor
        end

        keyBtn.MouseButton1Click:Connect(StartListening)

        lib:Connect(UserInputService.InputBegan, function(input, gpe)
            if not listening then return end
            if input.UserInputType ~= Enum.UserInputType.Keyboard then return end
            listening = false
            local keyName = input.KeyCode.Name
            currentKey = keyName
            kpObj.Value = keyName
            keyBtn.Text = keyName
            keyBtn.TextColor3 = Color3.fromRGB(90, 85, 120)
            pcall(opts.ChangedCallback or function() end, keyName)
        end)

        function kpObj:SetValue(data)
            if type(data) == "table" then
                currentKey = data[1] or currentKey
                mode = data[2] or mode
                self.Modifiers = data[3] or {}
            else
                currentKey = tostring(data)
            end
            keyBtn.Text = currentKey
            self.Value = currentKey
            self.Mode = mode
        end

        lib.Options[id] = kpObj
        return kpObj
    end

    return gbObj
end

