-- 7. NOTIFICATIONS
-- ════════════════════════════════════════════════════════════════════════════
local NotifHolder = nil

local function EnsureNotifHolder(library)
    if NotifHolder and NotifHolder.Parent then return end
    local sg = library.ScreenGui
    if not sg then return end

    NotifHolder = New("Frame", {
        Name = "Notifications",
        Size = UDim2.fromOffset(280, 0),
        AutomaticSize = Enum.AutomaticSize.Y,
        BackgroundTransparency = 1,
        AnchorPoint = Vector2.new(1, 1),
        Position = UDim2.new(1, -14, 1, -14),
        ZIndex = 50,
        Parent = sg,
    })
    MakeList(Enum.FillDirection.Vertical, 6, NotifHolder)
end

function Library:Notify(text, duration, notifType)
    EnsureNotifHolder(self)
    if not NotifHolder then return end

    duration = duration or 4
    notifType = notifType or "info"

    local colors = {
        info    = Color3.fromRGB(85, 175, 235),
        success = Color3.fromRGB(80, 200, 120),
        warning = Color3.fromRGB(240, 180, 60),
        error   = Color3.fromRGB(220, 75, 75),
        accent  = self.Scheme.AccentColor,
    }
    local accentColor = colors[notifType] or colors.info

    local card = New("Frame", {
        Size = UDim2.new(1, 0, 0, 56),
        BackgroundColor3 = Color3.fromRGB(7, 6, 14),
        ClipsDescendants = true,
        ZIndex = 51,
        Parent = NotifHolder,
    })
    MakeCorner(8, card)
    MakeStroke(Color3.fromRGB(16,15,26), 1, card)

    -- Accent strip
    New("Frame", {
        Size = UDim2.new(0, 3, 1, 0),
        BackgroundColor3 = accentColor,
        ZIndex = 52,
        Parent = card,
    })

    -- Title
    New("TextLabel", {
        Text = notifType:sub(1,1):upper() .. notifType:sub(2),
        Font = Enum.Font.GothamBold,
        TextSize = 12,
        TextColor3 = Color3.fromRGB(255, 255, 255),
        BackgroundTransparency = 1,
        Size = UDim2.new(1, -40, 0, 16),
        Position = UDim2.fromOffset(12, 8),
        TextXAlignment = Enum.TextXAlignment.Left,
        ZIndex = 52,
        Parent = card,
    })

    -- Body
    New("TextLabel", {
        Text = text,
        Font = Enum.Font.Gotham,
        TextSize = 11,
        TextColor3 = Color3.fromRGB(90, 85, 120),
        BackgroundTransparency = 1,
        Size = UDim2.new(1, -40, 0, 24),
        Position = UDim2.fromOffset(12, 26),
        TextXAlignment = Enum.TextXAlignment.Left,
        TextWrapped = true,
        ZIndex = 52,
        Parent = card,
    })

    -- Bottom fill bar
    local bar = New("Frame", {
        Size = UDim2.new(1, -3, 0, 2),
        Position = UDim2.new(0, 3, 1, -2),
        BackgroundColor3 = accentColor,
        BackgroundTransparency = 0.5,
        ZIndex = 52,
        Parent = card,
    })
    Tween(bar, TweenInfo.new(duration, Enum.EasingStyle.Linear), {
        Size = UDim2.new(0, 0, 0, 2)
    })

    -- Slide in
    card.Position = UDim2.fromOffset(280, 0)
    Tween(card, FAST_TWEEN, { Position = UDim2.fromOffset(0, 0) })

    task.delay(duration, function()
        Tween(card, FAST_TWEEN, { BackgroundTransparency = 1 })
        task.wait(0.15)
        card:Destroy()
    end)
end

