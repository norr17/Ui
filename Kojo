-- 14. CONFIG SYSTEM (embedded, executor-workspace-aware)
-- ════════════════════════════════════════════════════════════════════════════
Library.Config = {}

Library.Config.Folder    = "KojoHub"
Library.Config.SubFolder = ""
Library.Config.Ignore    = {}

function Library.Config:SetFolder(folder)
    self.Folder = folder
    self:BuildFolderTree()
end

function Library.Config:SetSubFolder(sub)
    self.SubFolder = sub
    self:BuildFolderTree()
end

function Library.Config:BuildFolderTree()
    local paths = {
        self.Folder,
        self.Folder .. "/themes",
        self.Folder .. "/settings",
    }
    if self.SubFolder and self.SubFolder ~= "" then
        table.insert(paths, self.Folder .. "/settings/" .. self.SubFolder)
    end
    for _, p in ipairs(paths) do
        if not isfolder(p) then
            pcall(makefolder, p)
        end
    end
end

function Library.Config:GetFilePath(name)
    local base = self.Folder .. "/settings/"
    if self.SubFolder and self.SubFolder ~= "" then
        base = base .. self.SubFolder .. "/"
    end
    return base .. name .. ".json"
end

function Library.Config:RefreshList()
    self:BuildFolderTree()
    local dir = self.Folder .. "/settings/"
    if self.SubFolder and self.SubFolder ~= "" then
        dir = dir .. self.SubFolder .. "/"
    end
    local ok, files = pcall(listfiles, dir)
    if not ok then return {} end
    local out = {}
    for _, f in ipairs(files or {}) do
        if f:sub(-5) == ".json" then
            local name = f:match("([^/\\]+)%.json$")
            if name then table.insert(out, name) end
        end
    end
    return out
end

function Library.Config:Save(name)
    self:BuildFolderTree()
    local lib = Library
    local data = { objects = {} }

    for id, t in pairs(lib.Toggles) do
        if not self.Ignore[id] then
            table.insert(data.objects, { type="Toggle", idx=id, value=t.Value })
        end
    end
    for id, o in pairs(lib.Options) do
        if not self.Ignore[id] then
            if o.Type == "Slider" then
                table.insert(data.objects, { type="Slider", idx=id, value=tostring(o.Value) })
            elseif o.Type == "Dropdown" then
                table.insert(data.objects, { type="Dropdown", idx=id, value=o.Value })
            elseif o.Type == "ColorPicker" then
                table.insert(data.objects, { type="ColorPicker", idx=id, value=o.Value:ToHex(), transparency=o.Transparency })
            elseif o.Type == "KeyPicker" then
                table.insert(data.objects, { type="KeyPicker", idx=id, key=o.Value, mode=o.Mode })
            elseif o.Type == "Input" then
                table.insert(data.objects, { type="Input", idx=id, text=o.Value })
            end
        end
    end

    local ok, encoded = pcall(function() return HttpService:JSONEncode(data) end)
    if not ok then return false, "encode error" end
    local path = self:GetFilePath(name)
    pcall(writefile, path, encoded)
    return true
end

function Library.Config:Load(name)
    self:BuildFolderTree()
    local lib = Library
    local path = self:GetFilePath(name)
    if not isfile(path) then return false, "file not found" end

    local ok, decoded = pcall(function()
        return HttpService:JSONDecode(readfile(path))
    end)
    if not ok then return false, "decode error" end

    for _, entry in ipairs(decoded.objects or {}) do
        if not self.Ignore[entry.idx] then
            if entry.type == "Toggle" and lib.Toggles[entry.idx] then
                lib.Toggles[entry.idx]:SetValue(entry.value)
            elseif entry.type == "Slider" and lib.Options[entry.idx] then
                lib.Options[entry.idx]:SetValue(tonumber(entry.value) or 0)
            elseif entry.type == "Dropdown" and lib.Options[entry.idx] then
                lib.Options[entry.idx]:SetValue(entry.value)
            elseif entry.type == "ColorPicker" and lib.Options[entry.idx] then
                lib.Options[entry.idx]:SetValueRGB(Color3.fromHex(entry.value), entry.transparency)
            elseif entry.type == "KeyPicker" and lib.Options[entry.idx] then
                lib.Options[entry.idx]:SetValue({ entry.key, entry.mode })
            elseif entry.type == "Input" and lib.Options[entry.idx] then
                lib.Options[entry.idx]:SetValue(entry.text)
            end
        end
    end
    return true
end

function Library.Config:Delete(name)
    local path = self:GetFilePath(name)
    if not isfile(path) then return false, "not found" end
    pcall(delfile, path)
    return true
end

function Library.Config:SetIgnoreIndexes(list)
    for _, k in ipairs(list) do self.Ignore[k] = true end
end

function Library.Config:BuildConfigSection(tab)
    -- Builds a config manager groupbox on the given tab
    local lib = Library
    local box = tab:AddLeftGroupbox("Config Manager")

    local configs = self:RefreshList()
    local currentConfig = configs[1] or ""

    local dd = box:AddDropdown("ConfigFile", {
        Text = "Config File",
        Values = #configs > 0 and configs or { "(none)" },
        Default = currentConfig,
        Callback = function(v) currentConfig = v end,
    })

    box:AddButton("LoadConfig", {
        Text = "Load",
        Variant = "primary",
        Func = function()
            local ok, err = self:Load(currentConfig)
            lib:Notify(ok and ("Loaded: " .. currentConfig) or ("Error: " .. (err or "")), 3, ok and "success" or "error")
        end,
    })

    box:AddButton("SaveConfig", {
        Text = "Save",
        Func = function()
            local ok, err = self:Save(currentConfig)
            lib:Notify(ok and ("Saved: " .. currentConfig) or ("Error: " .. (err or "")), 3, ok and "success" or "error")
        end,
    })

    box:AddButton("DeleteConfig", {
        Text = "Delete",
        Variant = "danger",
        Func = function()
            local ok, err = self:Delete(currentConfig)
            if ok then
                configs = self:RefreshList()
                lib:Notify("Deleted: " .. currentConfig, 3, "warning")
            else
                lib:Notify("Error: " .. (err or ""), 3, "error")
            end
        end,
    })

    box:AddSeparator()

    local newNameInput = box:AddInput("NewConfigName", {
        Text = "New Config Name",
        Placeholder = "e.g. pvp_config",
    })

    box:AddButton("CreateConfig", {
        Text = "Create & Save",
        Func = function()
            local name = newNameInput.Value:gsub("%s+", "_")
            if name == "" then lib:Notify("Enter a config name", 2, "warning"); return end
            local ok, err = self:Save(name)
            lib:Notify(ok and ("Created: " .. name) or ("Error: " .. (err or "")), 3, ok and "success" or "error")
            if ok then
                table.insert(configs, name)
                currentConfig = name
            end
        end,
    })

    box:AddSeparator()

    box:AddButton("RefreshConfigList", {
        Text = "↺ Refresh List",
        Func = function()
            configs = self:RefreshList()
            lib:Notify("Config list refreshed (" .. #configs .. " files)", 2, "info")
        end,
    })
end

