-- 3. CONNECTION MANAGER
-- ════════════════════════════════════════════════════════════════════════════
function Library:Connect(signal, fn)
    local conn = signal:Connect(fn)
    table.insert(self.Connections, conn)
    return conn
end

function Library:AddUnloadFunc(fn)
    table.insert(self.UnloadFuncs, fn)
end

