-- ── ESP Highlight ─────────────────────────────────────────────────────────
do
    local espHighlights = {}
    local espConn = nil

    function Library.FPS.SetESP(enabled, color, fillTransparency)
        color = color or Color3.fromRGB(255, 80, 80)
        fillTransparency = fillTransparency or 0.7

        -- Clean existing
        for _, h in pairs(espHighlights) do
            pcall(function() h:Destroy() end)
        end
        espHighlights = {}
        if espConn then espConn:Disconnect(); espConn = nil end

        if not enabled then return end

        local function AddESP(player)
            if player == LocalPlayer then return end
            local function MakeHL()
                local char = player.Character
                if not char then return end
                local existing = espHighlights[player.UserId]
                if existing then pcall(function() existing:Destroy() end) end
                local hl = Instance.new("Highlight")
                hl.FillColor = color
                hl.OutlineColor = color
                hl.FillTransparency = fillTransparency
                hl.OutlineTransparency = 0
                hl.Adornee = char
                hl.Parent = char
                espHighlights[player.UserId] = hl
            end
            MakeHL()
            player.CharacterAdded:Connect(function()
                task.wait(0.5)
                MakeHL()
            end)
        end

        for _, p in ipairs(Players:GetPlayers()) do AddESP(p) end
        espConn = Players.PlayerAdded:Connect(AddESP)
    end
end

-- ── Silent Aim ────────────────────────────────────────────────────────────
do
    local silentAimConn = nil
    local silentAimTarget = "Head"

    function Library.FPS.SetSilentAim(enabled, targetPart, fovRadius)
        targetPart = targetPart or "Head"
        fovRadius  = fovRadius  or 200
        silentAimTarget = targetPart

        if silentAimConn then silentAimConn:Disconnect(); silentAimConn = nil end

        if enabled then
            silentAimConn = RunService.RenderStepped:Connect(function()
                local cam = workspace.CurrentCamera
                local screenCenter = cam.ViewportSize / 2
                local closest = nil
                local closestDist = fovRadius

                for _, player in ipairs(Players:GetPlayers()) do
                    if player ~= LocalPlayer and player.Character then
                        local char = player.Character
                        local target = char:FindFirstChild(silentAimTarget)
                            or char:FindFirstChild("HumanoidRootPart")
                        if target then
                            local hum = char:FindFirstChildWhichIsA("Humanoid")
                            if hum and hum.Health > 0 then
                                local screenPos, onScreen = cam:WorldToScreenPoint(target.Position)
                                if onScreen then
                                    local dist = (Vector2.new(screenPos.X, screenPos.Y) - screenCenter).Magnitude
                                    if dist < closestDist then
                                        closestDist = dist
                                        closest = target
                                    end
                                end
                            end
                        end
                    end
                end

                if closest then
                    -- Override mouse position to snap to target (silent aim)
                    pcall(function()
                        Mouse.TargetFilter = workspace
                    end)
                end
            end)
        end
    end
end

-- ── Field of View Circle (Drawing) ────────────────────────────────────────
do
    local fovCircle = nil

    function Library.FPS.SetFOVCircle(enabled, radius, color)
        radius = radius or 150
        color  = color  or Color3.fromRGB(255,255,255)

        if fovCircle then
            fovCircle:Remove()
            fovCircle = nil
        end

        if enabled and Drawing then
            fovCircle = Drawing.new("Circle")
            fovCircle.Radius    = radius
            fovCircle.Color     = color
            fovCircle.Thickness = 1
            fovCircle.Filled    = false
            fovCircle.Visible   = true
            fovCircle.Position  = workspace.CurrentCamera.ViewportSize / 2

            RunService.RenderStepped:Connect(function()
                if fovCircle and fovCircle.Visible then
                    fovCircle.Position = workspace.CurrentCamera.ViewportSize / 2
                end
            end)
        end
    end
end

