-- 9. TOGGLE / SHOW WINDOW
-- ════════════════════════════════════════════════════════════════════════════
function Library:Toggle(state)
    if state == nil then
        self.Toggled = not self.Toggled
    else
        self.Toggled = state
    end
    if self.ScreenGui then
        self.ScreenGui.Enabled = self.Toggled
    end
end

