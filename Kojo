-- 8. CREATE WINDOW
-- ════════════════════════════════════════════════════════════════════════════
function Library:CreateWindow(opts)
    opts = opts or {}
    local title           = opts.Title          or "Kojo Hub"
    local footer          = opts.Footer         or "v2.0"
    local toggleKey       = opts.ToggleKeybind  or Enum.KeyCode.RightControl
    local notifySide      = opts.NotifySide     or "Right"
    local showCursor      = opts.ShowCustomCursor or false
    local windowIcon      = opts.Icon           or ""
    local center          = opts.Center         ~= false

    self.ToggleKeybind = toggleKey
    self.NotifySide    = notifySide

    -- Run loading if configured
    if LoadingData then
        ShowLoadingScreen(LoadingData)
        LoadingData = nil
        -- Wait a bit for loading to complete
        task.wait(#({ "Initializing...", "Loading settings...", "Preparing UI...", "Ready!" }) * 0.75 + 1.2)
    end

    -- Screen Gui
    local sg = New("ScreenGui", {
        Name = "KojoHub",
        ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
        IgnoreGuiInset = true,
        DisplayOrder = 10,
        ResetOnSpawn = false,
        Parent = GetGuiContainer(),
    })
    protectgui(sg)
    self.ScreenGui = sg

    -- Window frame
    local screenSize = workspace.CurrentCamera.ViewportSize
    local windowSize = Vector2.new(760, 580)
    local startPos   = center
        and UDim2.fromOffset(
            math.floor((screenSize.X - windowSize.X) / 2),
            math.floor((screenSize.Y - windowSize.Y) / 2)
        )
        or UDim2.fromOffset(80, 80)

    local window = New("Frame", {
        Name = "Window",
        Size = UDim2.fromOffset(windowSize.X, windowSize.Y),
        Position = startPos,
        BackgroundColor3 = self.Scheme.BackgroundColor,
        BorderSizePixel = 0,
        ZIndex = 2,
        ClipsDescendants = true,
        Parent = sg,
    })
    MakeCorner(10, window)
    MakeStroke(self.Scheme.OutlineColor, 1, window)
    self:RegisterColor(window, "BackgroundColor3", "BackgroundColor")

    -- Shadow
    New("ImageLabel", {
        Name = "Shadow",
        Size = UDim2.new(1, 40, 1, 40),
        Position = UDim2.fromOffset(-20, -20),
        BackgroundTransparency = 1,
        Image = "rbxassetid://6014261993",
        ImageColor3 = Color3.fromRGB(0, 0, 0),
        ImageTransparency = 0.5,
        ZIndex = 1,
        Parent = window,
    })

    -- ── Titlebar ───────────────────────────────────────────────────────────
    local titlebar = New("Frame", {
        Name = "Titlebar",
        Size = UDim2.new(1, 0, 0, 40),
        BackgroundColor3 = Color3.fromRGB(3, 2, 10),
        ZIndex = 3,
        Parent = window,
    })

    -- Logo / Icon
    local iconFrame = New("Frame", {
        Name = "IconFrame",
        Size = UDim2.fromOffset(46, 40),
        BackgroundTransparency = 1,
        ZIndex = 4,
        Parent = titlebar,
    })
    if windowIcon ~= "" then
        New("ImageLabel", {
            Size = UDim2.fromOffset(26, 26),
            Position = UDim2.fromOffset(10, 7),
            BackgroundTransparency = 1,
            Image = windowIcon,
            ZIndex = 5,
            Parent = iconFrame,
        })
    end

    -- Breadcrumb/title area
    local titleLabel = New("TextLabel", {
        Name = "Title",
        Text = title,
        Font = Enum.Font.GothamBold,
        TextSize = 12,
        TextColor3 = Color3.fromRGB(90, 85, 120),
        BackgroundTransparency = 1,
        Size = UDim2.new(0, 200, 1, 0),
        Position = UDim2.fromOffset(46, 0),
        TextXAlignment = Enum.TextXAlignment.Left,
        ZIndex = 4,
        Parent = titlebar,
    })

    local breadcrumbLabel = New("TextLabel", {
        Name = "Breadcrumb",
        Text = "",
        Font = Enum.Font.GothamMedium,
        TextSize = 12,
        TextColor3 = Color3.fromRGB(255, 255, 255),
        BackgroundTransparency = 1,
        Size = UDim2.new(1, -300, 1, 0),
        Position = UDim2.fromOffset(120, 0),
        TextXAlignment = Enum.TextXAlignment.Left,
        ZIndex = 4,
        Parent = titlebar,
    })

    -- FPS counter
    local fpsLabel = New("TextLabel", {
        Name = "FPS",
        Text = "FPS: 60",
        Font = Enum.Font.GothamMedium,
        TextSize = 10,
        TextColor3 = Color3.fromRGB(80, 200, 120),
        BackgroundTransparency = 1,
        Size = UDim2.fromOffset(70, 40),
        Position = UDim2.new(1, -160, 0, 0),
        TextXAlignment = Enum.TextXAlignment.Right,
        ZIndex = 4,
        Parent = titlebar,
    })

    -- Watermark
    local watermarkLabel = New("TextLabel", {
        Name = "Watermark",
        Text = title .. " " .. footer,
        Font = Enum.Font.GothamBold,
        TextSize = 10,
        TextColor3 = self.Scheme.AccentColor,
        BackgroundTransparency = 1,
        Size = UDim2.fromOffset(120, 40),
        Position = UDim2.new(1, -128, 0, 0),
        TextXAlignment = Enum.TextXAlignment.Right,
        ZIndex = 4,
        Parent = titlebar,
    })
    self:RegisterColor(watermarkLabel, "TextColor3", "AccentColor")

    -- Close / minimise buttons
    local closeBtn = New("TextButton", {
        Text = "×",
        Font = Enum.Font.GothamBold,
        TextSize = 16,
        TextColor3 = Color3.fromRGB(100, 95, 125),
        BackgroundTransparency = 1,
        Size = UDim2.fromOffset(28, 40),
        Position = UDim2.new(1, -30, 0, 0),
        ZIndex = 5,
        Parent = titlebar,
    })
    closeBtn.MouseButton1Click:Connect(function()
        self:Toggle(false)
    end)

    -- ── Drag ──────────────────────────────────────────────────────────────
    do
        local dragging, dragOffset = false, Vector2.new()
        titlebar.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                dragging = true
                dragOffset = Vector2.new(
                    input.Position.X - window.AbsolutePosition.X,
                    input.Position.Y - window.AbsolutePosition.Y
                )
            end
        end)
        self:Connect(UserInputService.InputChanged, function(input)
            if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
                local cam = workspace.CurrentCamera
                local nx = math.clamp(input.Position.X - dragOffset.X, 0, cam.ViewportSize.X - window.AbsoluteSize.X)
                local ny = math.clamp(input.Position.Y - dragOffset.Y, 0, cam.ViewportSize.Y - window.AbsoluteSize.Y)
                window.Position = UDim2.fromOffset(nx, ny)
            end
        end)
        self:Connect(UserInputService.InputEnded, function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                dragging = false
            end
        end)
    end

    -- ── Content area: sidebar + main ──────────────────────────────────────
    local contentFrame = New("Frame", {
        Name = "Content",
        Size = UDim2.new(1, 0, 1, -40),
        Position = UDim2.fromOffset(0, 40),
        BackgroundTransparency = 1,
        ZIndex = 3,
        Parent = window,
    })

    -- Sidebar (left, icon-only, 46px)
    local sidebar = New("Frame", {
        Name = "Sidebar",
        Size = UDim2.new(0, 46, 1, 0),
        BackgroundColor3 = Color3.fromRGB(3, 2, 10),
        ZIndex = 4,
        Parent = contentFrame,
    })
    New("Frame", {
        Name = "SidebarBorder",
        Size = UDim2.new(0, 1, 1, 0),
        Position = UDim2.new(1, -1, 0, 0),
        BackgroundColor3 = Color3.fromRGB(12, 11, 20),
        ZIndex = 5,
        Parent = sidebar,
    })

    local sidebarList = New("Frame", {
        Size = UDim2.new(1, 0, 1, -32),
        BackgroundTransparency = 1,
        ZIndex = 5,
        Parent = sidebar,
    })
    MakeList(Enum.FillDirection.Vertical, 3, sidebarList)
    MakePadding(8, 5, 0, 5, sidebarList)

    -- Bottom reload button
    local reloadBtn = New("TextButton", {
        Text = "↺",
        Font = Enum.Font.GothamBold,
        TextSize = 14,
        TextColor3 = Color3.fromRGB(40, 38, 55),
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 0, 30),
        Position = UDim2.new(0, 0, 1, -30),
        ZIndex = 5,
        Parent = sidebar,
    })

    -- Main content (right of sidebar)
    local mainFrame = New("Frame", {
        Name = "Main",
        Size = UDim2.new(1, -46, 1, 0),
        Position = UDim2.fromOffset(46, 0),
        BackgroundTransparency = 1,
        ZIndex = 4,
        Parent = contentFrame,
    })

    -- Subtab bar (breadcrumb tabs at top of main)
    local subtabBar = New("Frame", {
        Name = "SubtabBar",
        Size = UDim2.new(1, 0, 0, 34),
        BackgroundColor3 = Color3.fromRGB(2, 1, 9),
        ZIndex = 5,
        Parent = mainFrame,
    })
    New("Frame", {
        Size = UDim2.new(1, 0, 0, 1),
        Position = UDim2.new(0, 0, 1, -1),
        BackgroundColor3 = Color3.fromRGB(12, 11, 20),
        ZIndex = 6,
        Parent = subtabBar,
    })
    local subtabList = New("Frame", {
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        ZIndex = 6,
        Parent = subtabBar,
    })
    MakeList(Enum.FillDirection.Horizontal, 0, subtabList)
    MakePadding(0, 6, 0, 6, subtabList)

    -- Tab container
    local tabContainer = New("Frame", {
        Name = "TabContainer",
        Size = UDim2.new(1, 0, 1, -34),
        Position = UDim2.fromOffset(0, 34),
        BackgroundTransparency = 1,
        ClipsDescendants = true,
        ZIndex = 5,
        Parent = mainFrame,
    })

    -- FPS update
    local lastTime, fpsCount, fpsBuf = os.clock(), 0, 0
    local fpsConn = RunService.RenderStepped:Connect(function()
        fpsCount += 1
        local now = os.clock()
        if now - lastTime >= 0.5 then
            fpsBuf = math.floor(fpsCount / (now - lastTime))
            fpsCount = 0
            lastTime = now
            local col = fpsBuf >= 50 and Color3.fromRGB(80,200,120) or fpsBuf >= 30 and Color3.fromRGB(240,180,60) or Color3.fromRGB(220,75,75)
            fpsLabel.TextColor3 = col
            fpsLabel.Text = "FPS: " .. fpsBuf
        end
    end)
    self:AddUnloadFunc(function() fpsConn:Disconnect() end)

    -- Keybind toggle
    self:Connect(UserInputService.InputBegan, function(input, gpe)
        if gpe then return end
        if input.KeyCode == self.ToggleKeybind then
            self:Toggle()
        end
    end)

    -- ── Window Object ──────────────────────────────────────────────────────
    local windowObj = {}
    windowObj._lib          = self
    windowObj._frame        = window
    windowObj._sidebar      = sidebarList
    windowObj._subtabBar    = subtabList
    windowObj._tabContainer = tabContainer
    windowObj._breadcrumb   = breadcrumbLabel
    windowObj._categories   = {}
    windowObj._activeCategory = nil
    windowObj._activeCategoryBtn = nil

    function windowObj:_setActiveCategory(cat)
        self._activeCategory = cat
        -- Update subtab bar
        for _, child in ipairs(self._subtabBar:GetChildren()) do
            if child:IsA("TextButton") then child:Destroy() end
        end
        -- Show tabs
        for _, tab in ipairs(cat._tabs) do
            tab._frame.Visible = false
        end
        if #cat._tabs > 0 then
            self:_setActiveTab(cat, cat._tabs[1])
        end
    end

    function windowObj:_setActiveTab(cat, tabObj)
        for _, tab in ipairs(cat._tabs) do
            tab._frame.Visible = false
        end
        tabObj._frame.Visible = true

        -- Rebuild subtab buttons
        for _, child in ipairs(self._subtabBar:GetChildren()) do
            if not child:IsA("UIListLayout") and not child:IsA("UIPadding") then
                child:Destroy()
            end
        end

        -- Breadcrumb prefix
        local lib = self._lib
        local accentHex = string.format("#%02x%02x%02x", math.floor(lib.Scheme.AccentColor.R*255), math.floor(lib.Scheme.AccentColor.G*255), math.floor(lib.Scheme.AccentColor.B*255))
        self._breadcrumb.Text = ""

        for i, tab in ipairs(cat._tabs) do
            local isActive = (tab == tabObj)
            local btn = New("TextButton", {
                Text = tab._name,
                Font = isActive and Enum.Font.GothamBold or Enum.Font.Gotham,
                TextSize = 11,
                TextColor3 = isActive and lib.Scheme.AccentColor or Color3.fromRGB(40, 38, 55),
                BackgroundTransparency = 1,
                AutomaticSize = Enum.AutomaticSize.X,
                Size = UDim2.fromOffset(0, 34),
                ZIndex = 7,
                Parent = self._subtabBar,
            })
            MakePadding(0, 8, 0, 8, btn)

            if isActive then
                -- Active underline
                New("Frame", {
                    Size = UDim2.new(1, -16, 0, 2),
                    Position = UDim2.new(0, 8, 1, -2),
                    BackgroundColor3 = lib.Scheme.AccentColor,
                    ZIndex = 8,
                    Parent = btn,
                })
            end

            btn.MouseButton1Click:Connect(function()
                self:_setActiveTab(cat, tab)
            end)
        end
    end

    function windowObj:AddCategory(opts)
        opts = opts or {}
        local name = opts.Name or "Category"
        local icon = opts.Icon or ""

        local cat = {}
        cat._name   = name
        cat._icon   = icon
        cat._tabs   = {}
        cat._window = self

        -- Sidebar icon button
        local isFirst = #self._categories == 0
        local btn = New("TextButton", {
            Name = name,
            Text = "",
            BackgroundColor3 = isFirst and self._lib.Scheme.AccentColor:Lerp(Color3.fromRGB(0,0,0), 0.8) or Color3.fromRGB(0,0,0),
            BackgroundTransparency = isFirst and 0 or 1,
            Size = UDim2.fromOffset(36, 36),
            ZIndex = 6,
            Parent = self._sidebar,
        })
        MakeCorner(8, btn)

        if icon ~= "" then
            New("ImageLabel", {
                Size = UDim2.fromOffset(20, 20),
                Position = UDim2.fromOffset(8, 8),
                BackgroundTransparency = 1,
                Image = icon,
                ImageColor3 = isFirst and self._lib.Scheme.AccentColor or Color3.fromRGB(45, 42, 65),
                ZIndex = 7,
                Parent = btn,
            })
        else
            -- Fallback: show first letter
            New("TextLabel", {
                Text = name:sub(1,1),
                Font = Enum.Font.GothamBold,
                TextSize = 14,
                TextColor3 = isFirst and self._lib.Scheme.AccentColor or Color3.fromRGB(45, 42, 65),
                BackgroundTransparency = 1,
                Size = UDim2.fromScale(1, 1),
                ZIndex = 7,
                Parent = btn,
            })
        end

        cat._btn = btn

        if isFirst then
            self._activeCategoryBtn = btn
            self._activeCategory    = cat
        end

        btn.MouseButton1Click:Connect(function()
            -- Deactivate previous
            if self._activeCategoryBtn and self._activeCategoryBtn ~= btn then
                local prevBg = self._activeCategoryBtn:FindFirstChildWhichIsA("Frame")
                Tween(self._activeCategoryBtn, FAST_TWEEN, { BackgroundTransparency = 1 })
                for _, c in ipairs(self._activeCategoryBtn:GetChildren()) do
                    if c:IsA("ImageLabel") or c:IsA("TextLabel") then
                        Tween(c, FAST_TWEEN, { ImageColor3 = Color3.fromRGB(45,42,65), TextColor3 = Color3.fromRGB(45,42,65) })
                    end
                end
            end
            -- Activate this
            Tween(btn, FAST_TWEEN, { BackgroundTransparency = 0 })
            btn.BackgroundColor3 = self._lib.Scheme.AccentColor:Lerp(Color3.fromRGB(0,0,0), 0.8)
            for _, c in ipairs(btn:GetChildren()) do
                if c:IsA("ImageLabel") or c:IsA("TextLabel") then
                    Tween(c, FAST_TWEEN, { ImageColor3 = self._lib.Scheme.AccentColor, TextColor3 = self._lib.Scheme.AccentColor })
                end
            end
            self._activeCategoryBtn = btn
            self:_setActiveCategory(cat)
        end)

        function cat:AddTab(tabName)
            local tabObj = {}
            tabObj._name    = tabName
            tabObj._cat     = self
            tabObj._window  = self._window
            tabObj._lib     = self._window._lib

            -- Tab frame (scrollable, 2-col layout)
            local frame = New("ScrollingFrame", {
                Name = tabName,
                Size = UDim2.fromScale(1, 1),
                BackgroundTransparency = 1,
                ScrollBarThickness = 3,
                ScrollBarImageColor3 = Color3.fromRGB(40,38,55),
                CanvasSize = UDim2.fromScale(0, 0),
                AutomaticCanvasSize = Enum.AutomaticSize.Y,
                Visible = false,
                ZIndex = 6,
                Parent = self._window._tabContainer,
            })
            MakePadding(8, 8, 8, 8, frame)

            -- 2-column layout
            local cols = New("Frame", {
                Name = "Columns",
                Size = UDim2.new(1, 0, 0, 0),
                AutomaticSize = Enum.AutomaticSize.Y,
                BackgroundTransparency = 1,
                ZIndex = 6,
                Parent = frame,
            })
            local colGrid = Instance.new("UIGridLayout")
            colGrid.CellSize = UDim2.new(0.5, -5, 0, 0)
            colGrid.CellPadding = UDim2.fromOffset(10, 10)
            colGrid.FillDirection = Enum.FillDirection.Horizontal
            colGrid.SortOrder = Enum.SortOrder.LayoutOrder
            colGrid.Parent = cols

            -- Resize cols frame height to tallest column
            local function updateColsHeight()
                local max = 0
                for _, child in ipairs(cols:GetChildren()) do
                    if child:IsA("Frame") then
                        max = math.max(max, child.AbsoluteSize.Y)
                    end
                end
                cols.Size = UDim2.fromOffset(cols.AbsoluteSize.X, max)
            end

            tabObj._frame    = frame
            tabObj._cols     = cols
            tabObj._leftCol  = nil
            tabObj._rightCol = nil
            tabObj._colCount = 0

            local function MakeColumn()
                tabObj._colCount += 1
                local col = New("Frame", {
                    Name = "Col" .. tabObj._colCount,
                    Size = UDim2.fromOffset(0, 0),
                    AutomaticSize = Enum.AutomaticSize.Y,
                    BackgroundTransparency = 1,
                    LayoutOrder = tabObj._colCount,
                    ZIndex = 6,
                    Parent = cols,
                })
                MakeList(Enum.FillDirection.Vertical, 8, col)
                return col
            end

            function tabObj:AddLeftGroupbox(gTitle, gIcon)
                if not self._leftCol then
                    self._leftCol = MakeColumn()
                end
                return tabObj._window._lib:_MakeGroupbox(self._leftCol, gTitle, gIcon)
            end

            function tabObj:AddRightGroupbox(gTitle, gIcon)
                if not self._rightCol then
                    self._rightCol = MakeColumn()
                end
                return tabObj._window._lib:_MakeGroupbox(self._rightCol, gTitle, gIcon)
            end

            -- Also support single groupbox spanning full width
            function tabObj:AddGroupbox(gTitle, gIcon)
                return self:AddLeftGroupbox(gTitle, gIcon)
            end

            table.insert(self._tabs, tabObj)

            -- If this is the first tab in the first category, show it
            if self._window._activeCategory == self and #self._tabs == 1 then
                frame.Visible = true
                self._window:_setActiveCategory(self)
            end

            return tabObj
        end

        table.insert(self._categories, cat)

        if isFirst then
            self:_setActiveCategory(cat)
        end

        return cat
    end

    function windowObj:_getFrame()
        return self._frame
    end

    table.insert(self._lib.UnloadFuncs, function()
        sg:Destroy()
    end)

    self._window = windowObj
    return windowObj
end

