        MakeCorner(4, swatch)
        MakeStroke(Color3.fromRGB(22,20,34), 1, swatch)

        local cpObj = { Value=val, Transparency=transp, Type="ColorPicker", Id=id }

        -- Simple color picker popup (hue/sat/val pickers omitted for brevity,
        -- using RGB inputs as practical alternative)
        local pickerOpen = false
        local pickerFrame = nil

        local function BuildPicker()
            if pickerFrame then pickerFrame:Destroy(); pickerFrame = nil; pickerOpen = false; return end
            pickerOpen = true

            pickerFrame = New("Frame", {
                Name = "ColorPicker",
                Size = UDim2.fromOffset(180, 100),
                Position = UDim2.new(0, 0, 1, 4),
                BackgroundColor3 = Color3.fromRGB(6,5,14),
                ZIndex = 200,
                Parent = row,
            })
            MakeCorner(8, pickerFrame)
            MakeStroke(Color3.fromRGB(20,18,30), 1, pickerFrame)
            MakePadding(8, 8, 8, 8, pickerFrame)

            local function MakeChannelInput(label, startVal, onChange)
                local ch = New("Frame", {
                    Size = UDim2.new(1, 0, 0, 22),
                    BackgroundTransparency = 1,
                    ZIndex = 201,
                    Parent = pickerFrame,
                })
                New("TextLabel", {
                    Text = label,
                    Font = Enum.Font.GothamBold,
                    TextSize = 10,
                    TextColor3 = Color3.fromRGB(80,75,110),
                    BackgroundTransparency = 1,
                    Size = UDim2.fromOffset(16, 22),
                    ZIndex = 202,
                    Parent = ch,
                })
                local inputBg2 = New("Frame", {
                    Size = UDim2.new(1, -20, 0, 18),
                    Position = UDim2.fromOffset(20, 2),
                    BackgroundColor3 = Color3.fromRGB(10,9,18),
                    ZIndex = 202,
                    Parent = ch,
                })
                MakeCorner(4, inputBg2)
                local box = New("TextBox", {
                    Text = tostring(math.floor(startVal)),
                    Font = Enum.Font.GothamMedium,
                    TextSize = 10,
                    TextColor3 = Color3.fromRGB(220,215,240),
                    BackgroundTransparency = 1,
                    Size = UDim2.fromScale(1,1),
                    ZIndex = 203,
                    Parent = inputBg2,
                })
                box.FocusLost:Connect(function()
                    local n = tonumber(box.Text)
                    if n then onChange(math.clamp(n, 0, 255)) end
                end)
                return ch
            end

            local r, g, b = math.floor(val.R*255), math.floor(val.G*255), math.floor(val.B*255)
            local rRow = MakeChannelInput("R", r, function(v) r=v; val=Color3.fromRGB(r,g,b); swatch.BackgroundColor3=val; cpObj.Value=val; pcall(callback,val) end)
            local gRow = MakeChannelInput("G", g, function(v) g=v; val=Color3.fromRGB(r,g,b); swatch.BackgroundColor3=val; cpObj.Value=val; pcall(callback,val) end)
            local bRow = MakeChannelInput("B", b, function(v) b=v; val=Color3.fromRGB(r,g,b); swatch.BackgroundColor3=val; cpObj.Value=val; pcall(callback,val) end)

            MakeList(Enum.FillDirection.Vertical, 4, pickerFrame)
            rRow.Parent = pickerFrame
            gRow.Parent = pickerFrame
            bRow.Parent = pickerFrame
        end

        if not disabled then
            swatch.MouseButton1Click:Connect(BuildPicker)
        end

        function cpObj:SetValueRGB(color, transparency)
            val = color or val
            transp = transparency or transp
            swatch.BackgroundColor3 = val
            self.Value = val
            self.Transparency = transp
            pcall(callback, val)
        end

        lib.Options[id] = cpObj
        return cpObj
    end

