                TextXAlignment = Enum.TextXAlignment.Left,
                ZIndex = 101,
                Parent = menu,
            })
            MakePadding(0, 0, 0, 10, btn)
            btn.MouseEnter:Connect(function()
                btn.BackgroundTransparency = 0.85
                btn.BackgroundColor3 = Color3.fromRGB(255,255,255)
            end)
            btn.MouseLeave:Connect(function()
                btn.BackgroundTransparency = 1
            end)
            btn.MouseButton1Click:Connect(function()
                pcall(item.Callback or function() end)
                menu:Destroy()
            end)
        end

        -- Close on outside click
        local closeConn
        closeConn = self:Connect(UserInputService.InputBegan, function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                task.wait()
                if menu and menu.Parent then
                    local mx, my = input.Position.X, input.Position.Y
                    local abs, sz = menu.AbsolutePosition, menu.AbsoluteSize
                    if not (mx >= abs.X and mx <= abs.X+sz.X and my >= abs.Y and my <= abs.Y+sz.Y) then
                        menu:Destroy()
                    end
                end
                closeConn:Disconnect()
            end
        end)
    end)
end

