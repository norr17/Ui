                        Size = UDim2.fromOffset(10, 24),
                        Position = UDim2.new(1, -14, 0, 0),
                        ZIndex = 102,
                        Parent = item,
                    })
                end
                item.MouseButton1Click:Connect(function()
                    selected = v
                    selLabel.Text = tostring(v)
                    dropObj.Value = v
                    pcall(callback, v)
                    if opts.Changed then pcall(opts.Changed, v) end
                    CloseDropdown()
                end)
                item.MouseEnter:Connect(function()
                    if v ~= selected then
                        Tween(item, FAST_TWEEN, { BackgroundTransparency = 0.85 })
                        item.BackgroundColor3 = Color3.fromRGB(255,255,255)
                    end
                end)
                item.MouseLeave:Connect(function()
                    if v ~= selected then
                        Tween(item, FAST_TWEEN, { BackgroundTransparency = 1 })
                    end
                end)
            end
        end

        btnFrame.MouseButton1Click:Connect(function()
            if not disabled then
                if open then CloseDropdown() else OpenDropdown() end
            end
        end)

        -- Close on outside click
        lib:Connect(UserInputService.InputBegan, function(input, gpe)
            if open and input.UserInputType == Enum.UserInputType.MouseButton1 then
                task.wait()
                if dropFrame and not dropFrame:IsDescendantOf(game) then return end
                local mx, my = input.Position.X, input.Position.Y
                if dropFrame then
                    local abs = dropFrame.AbsolutePosition
                    local sz  = dropFrame.AbsoluteSize
                    if not (mx >= abs.X and mx <= abs.X + sz.X and my >= abs.Y and my <= abs.Y + sz.Y) then
                        CloseDropdown()
                    end
                end
            end
        end)

        function dropObj:SetValue(v)
            selected = v
            selLabel.Text = tostring(v)
            self.Value = v
            pcall(callback, v)
        end

