-- 10. GROUPBOX
-- ════════════════════════════════════════════════════════════════════════════
function Library:_MakeGroupbox(parent, title, iconImg)
    local scheme = self.Scheme

    local box = New("Frame", {
        Name = title,
        Size = UDim2.fromScale(1, 0),
        AutomaticSize = Enum.AutomaticSize.Y,
        BackgroundColor3 = Color3.fromRGB(6, 5, 14),
        ZIndex = 7,
        Parent = parent,
    })
    MakeCorner(8, box)
    MakeStroke(Color3.fromRGB(15, 14, 24), 1, box)

    -- Header
    local header = New("Frame", {
        Name = "Header",
        Size = UDim2.new(1, 0, 0, 32),
        BackgroundTransparency = 1,
        ZIndex = 8,
        Parent = box,
    })
    New("Frame", {
        Size = UDim2.new(1, -24, 0, 1),
        Position = UDim2.new(0, 12, 1, -1),
        BackgroundColor3 = Color3.fromRGB(14, 13, 22),
        ZIndex = 8,
        Parent = header,
    })

    if iconImg and iconImg ~= "" then
        New("ImageLabel", {
            Size = UDim2.fromOffset(14, 14),
            Position = UDim2.fromOffset(10, 9),
            BackgroundTransparency = 1,
            Image = iconImg,
            ImageColor3 = Color3.fromRGB(45, 42, 65),
            ZIndex = 9,
            Parent = header,
        })
    end

    New("TextLabel", {
        Text = title,
        Font = Enum.Font.GothamBold,
        TextSize = 12,
        TextColor3 = Color3.fromRGB(255, 255, 255),
        BackgroundTransparency = 1,
        Size = UDim2.new(1, -50, 1, 0),
        Position = UDim2.fromOffset(iconImg ~= "" and 28 or 12, 0),
        TextXAlignment = Enum.TextXAlignment.Left,
        ZIndex = 9,
        Parent = header,
    })

    -- Content scroll
    local content = New("Frame", {
        Name = "Content",
        Size = UDim2.new(1, 0, 0, 0),
        AutomaticSize = Enum.AutomaticSize.Y,
        Position = UDim2.fromOffset(0, 32),
        BackgroundTransparency = 1,
        ZIndex = 8,
        Parent = box,
    })
    MakeList(Enum.FillDirection.Vertical, 0, content)
    MakePadding(2, 0, 6, 0, content)

    local gbObj = { _frame=box, _content=content, _lib=self }

    -- ── AddToggle ─────────────────────────────────────────────────────────
    function gbObj:AddToggle(id, opts)
        opts = opts or {}
        local text     = opts.Text     or id
        local default  = opts.Default  ~= nil and opts.Default or false
        local callback = opts.Callback or function() end
        local disabled = opts.Disabled or false
        local risky    = opts.Risky    or false

        local val = default
        local lib = self._lib

        local row = New("Frame", {
            Name = id,
            Size = UDim2.new(1, 0, 0, 28),
            BackgroundTransparency = 1,
            ZIndex = 9,
            Parent = self._content,
        })
        MakePadding(0, 10, 0, 10, row)

        local labelEl = New("TextLabel", {
            Text = text,
            Font = Enum.Font.Gotham,
            TextSize = 12,
            TextColor3 = default and Color3.fromRGB(255,255,255) or Color3.fromRGB(60,58,80),
            BackgroundTransparency = 1,
            Size = UDim2.new(1, -46, 1, 0),
            TextXAlignment = Enum.TextXAlignment.Left,
            ZIndex = 10,
            Parent = row,
        })

        -- Toggle pill
        local pillBg = New("Frame", {
            Name = "Pill",
            Size = UDim2.fromOffset(34, 18),
            Position = UDim2.new(1, -34, 0.5, -9),
            BackgroundColor3 = default and lib.Scheme.AccentColor or Color3.fromRGB(18,17,28),
            ZIndex = 10,
            Parent = row,
        })
        MakeCorner(9, pillBg)
        MakeStroke(default and lib.Scheme.AccentColor or Color3.fromRGB(26,24,40), 1, pillBg)

        local knob = New("Frame", {
            Name = "Knob",
            Size = UDim2.fromOffset(12, 12),
            Position = default and UDim2.fromOffset(19, 3) or UDim2.fromOffset(3, 3),
            BackgroundColor3 = default and Color3.fromRGB(240,235,255) or Color3.fromRGB(55,52,75),
            ZIndex = 11,
            Parent = pillBg,
        })
        MakeCorner(6, knob)

        local toggleObj = { Value=val, Type="Toggle", Id=id }

        local function SetValue(v)
            val = v
            toggleObj.Value = v
            local accent = lib.Scheme.AccentColor
            if not disabled then
                Tween(pillBg, FAST_TWEEN, { BackgroundColor3 = v and accent or Color3.fromRGB(18,17,28) })
                Tween(knob, FAST_TWEEN, {
                    Position = v and UDim2.fromOffset(19,3) or UDim2.fromOffset(3,3),
                    BackgroundColor3 = v and Color3.fromRGB(240,235,255) or Color3.fromRGB(55,52,75),
                })
                Tween(labelEl, FAST_TWEEN, { TextColor3 = v and Color3.fromRGB(255,255,255) or Color3.fromRGB(60,58,80) })
            end
            pcall(callback, v)
            if opts.Changed then pcall(opts.Changed, v) end
        end

        function toggleObj:SetValue(v) SetValue(v) end

        if not disabled then
            row.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    SetValue(not val)
                end
            end)
            row.MouseEnter:Connect(function()
                Tween(row, FAST_TWEEN, { BackgroundColor3 = Color3.fromRGB(10,9,18) })
                row.BackgroundTransparency = 0
            end)
            row.MouseLeave:Connect(function()
                row.BackgroundTransparency = 1
            end)
        else
            labelEl.TextColor3 = Color3.fromRGB(35,33,50)
            pillBg.BackgroundTransparency = 0.5
        end

        lib.Toggles[id] = toggleObj

        -- Addon chaining
        function toggleObj:AddColorPicker(cpId, cpOpts)
            cpOpts = cpOpts or {}
            return gbObj:AddColorPicker(cpId, cpOpts)
        end
        function toggleObj:AddKeyPicker(kpId, kpOpts)
            kpOpts = kpOpts or {}
            return gbObj:AddKeyPicker(kpId, kpOpts)
        end

        return toggleObj
    end

    -- ── AddSlider ─────────────────────────────────────────────────────────
    function gbObj:AddSlider(id, opts)
        opts = opts or {}
        local text     = opts.Text    or id
        local minVal   = opts.Min     or 0
        local maxVal   = opts.Max     or 100
        local default  = opts.Default or minVal
        local rounding = opts.Rounding or 0
        local suffix   = opts.Suffix  or ""
        local prefix   = opts.Prefix  or ""
        local callback = opts.Callback or function() end
        local disabled = opts.Disabled or false

        local val = math.clamp(default, minVal, maxVal)
        local lib = self._lib

        local row = New("Frame", {
            Name = id,
            Size = UDim2.new(1, 0, 0, 44),
            BackgroundTransparency = 1,
            ZIndex = 9,
            Parent = self._content,
        })
        MakePadding(0, 10, 4, 10, row)

        -- Top: label + value
        local labelEl = New("TextLabel", {
            Text = text,
            Font = Enum.Font.Gotham,
            TextSize = 12,
            TextColor3 = Color3.fromRGB(90, 85, 120),
            BackgroundTransparency = 1,
            Size = UDim2.new(1, -50, 0, 20),
            Position = UDim2.fromOffset(0, 0),
            TextXAlignment = Enum.TextXAlignment.Left,
            ZIndex = 10,
            Parent = row,
        })

        local function FormatValue(v)
            if rounding == 0 then
                return prefix .. tostring(math.floor(v)) .. suffix
            elseif rounding < 1 then
                local dec = math.max(0, -math.floor(math.log10(rounding)))
                return prefix .. string.format("%." .. dec .. "f", v) .. suffix
            else
                return prefix .. tostring(math.floor(v / rounding) * rounding) .. suffix
            end
        end

        local valueLabel = New("TextLabel", {
            Text = FormatValue(val),
            Font = Enum.Font.GothamMedium,
            TextSize = 10,
            TextColor3 = Color3.fromRGB(60, 58, 80),
            BackgroundTransparency = 1,
            Size = UDim2.fromOffset(48, 20),
            Position = UDim2.new(1, -48, 0, 0),
            TextXAlignment = Enum.TextXAlignment.Right,
            ZIndex = 10,
            Parent = row,
        })

        -- Track
        local track = New("Frame", {
            Name = "Track",
            Size = UDim2.new(1, 0, 0, 4),
            Position = UDim2.fromOffset(0, 26),
            BackgroundColor3 = Color3.fromRGB(18, 17, 28),
            ZIndex = 10,
            Parent = row,
        })
        MakeCorner(2, track)

        local fill = New("Frame", {
            Name = "Fill",
            Size = UDim2.fromScale(
                math.clamp((val - minVal) / math.max(0.001, maxVal - minVal), 0, 1),
                1
            ),
            BackgroundColor3 = lib.Scheme.AccentColor,
            ZIndex = 11,
            Parent = track,
        })
        MakeCorner(2, fill)
        lib:RegisterColor(fill, "BackgroundColor3", "AccentColor")

        local knob = New("Frame", {
            Name = "Knob",
            Size = UDim2.fromOffset(12, 12),
            AnchorPoint = Vector2.new(0.5, 0.5),
            Position = UDim2.new(
                math.clamp((val - minVal) / math.max(0.001, maxVal - minVal), 0, 1),
                0, 0.5, 0
            ),
            BackgroundColor3 = Color3.fromRGB(235, 228, 255),
            ZIndex = 12,
            Parent = track,
        })
        MakeCorner(6, knob)
        MakeStroke(lib.Scheme.AccentColor, 2, knob)
        lib:RegisterColor(knob, "BorderColor3", "AccentColor") -- stroke updates via Stroke child

        local sliderObj = { Value=val, Type="Slider", Id=id }

        local function SetValue(v)
            if rounding > 0 then
                v = math.floor(v / rounding + 0.5) * rounding
            end
            v = math.clamp(v, minVal, maxVal)
            v = math.floor(v * 10000 + 0.5) / 10000
            val = v
            sliderObj.Value = v

            local frac = (v - minVal) / math.max(0.001, maxVal - minVal)
            Tween(fill, FAST_TWEEN, { Size = UDim2.fromScale(frac, 1) })
            Tween(knob, FAST_TWEEN, { Position = UDim2.new(frac, 0, 0.5, 0) })
            valueLabel.Text = FormatValue(v)
            pcall(callback, v)
            if opts.Changed then pcall(opts.Changed, v) end
        end

        function sliderObj:SetValue(v) SetValue(v) end

        if not disabled then
            local dragging = false
            local function updateFromMouse(inputX)
                local abs  = track.AbsolutePosition.X
                local size = track.AbsoluteSize.X
                local frac = math.clamp((inputX - abs) / size, 0, 1)
                SetValue(minVal + frac * (maxVal - minVal))
            end

            track.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    dragging = true
                    updateFromMouse(input.Position.X)
                end
            end)
            lib:Connect(UserInputService.InputChanged, function(input)
                if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
                    updateFromMouse(input.Position.X)
                end
            end)
            lib:Connect(UserInputService.InputEnded, function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    dragging = false
                end
            end)
        end

        lib.Options[id] = sliderObj
        return sliderObj
    end

    -- ── AddDropdown ───────────────────────────────────────────────────────
    function gbObj:AddDropdown(id, opts)
        opts = opts or {}
        local text     = opts.Text     or id
        local values   = opts.Values   or {}
        local default  = opts.Default  or (values[1] or "")
        local multi    = opts.Multi    or false
        local callback = opts.Callback or function() end
        local disabled = opts.Disabled or false

