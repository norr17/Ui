-- ============================================================
-- FPS COUNTER OVERLAY
-- ============================================================

local FPSCounterClass = {}
FPSCounterClass.__index = FPSCounterClass

function FPSCounterClass.new(gui, opts)
    opts = opts or {}
    local position = opts.Position or UDim2.new(0, 12, 0, 12)

    local frame = Instance.new("Frame")
    frame.Name = "FPSCounter"
    frame.BackgroundColor3 = Color3.fromRGB(15, 15, 18)
    frame.BackgroundTransparency = 0.15
    frame.Position = position
    frame.Size = UDim2.new(0, 70, 0, 24)
    frame.ZIndex = 999
    frame.Parent = gui

    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 5)
    corner.Parent = frame

    local stroke = Instance.new("UIStroke")
    stroke.Color = Color3.fromRGB(35, 35, 42)
    stroke.Thickness = 1
    stroke.Parent = frame

    local label = Instance.new("TextLabel")
    label.BackgroundTransparency = 1
    label.Size = UDim2.new(1, 0, 1, 0)
    label.Text = "FPS: 60"
    label.Font = Enum.Font.GothamMedium
    label.TextSize = 11
    label.TextColor3 = Color3.fromRGB(80, 200, 120)
    label.Parent = frame

    local self = setmetatable({}, FPSCounterClass)
    self._frame = frame
    self._label = label
    self._conn = nil
    self._enabled = false

    local lastTime = tick()
    local frameCount = 0
    local fps = 60

    function self:Enable()
        if self._enabled then return end
        self._enabled = true
        self._conn = game:GetService("RunService").RenderStepped:Connect(function()
            frameCount = frameCount + 1
            local now = tick()
            local dt = now - lastTime
            if dt >= 0.5 then
                fps = math.round(frameCount / dt)
                frameCount = 0
                lastTime = now
                -- Color coding
                local fpsColor = Color3.fromRGB(80, 200, 120) -- green
                if fps < 30 then
                    fpsColor = Color3.fromRGB(220, 75, 75)   -- red
                elseif fps < 50 then
                    fpsColor = Color3.fromRGB(240, 180, 60)  -- yellow
                end
                label.Text = "FPS: " .. fps
                label.TextColor3 = fpsColor
            end
        end)
    end

    function self:Disable()
        self._enabled = false
        if self._conn then
            self._conn:Disconnect()
            self._conn = nil
        end
    end

    function self:SetVisible(v)
        frame.Visible = v
    end

    function self:Destroy()
        self:Disable()
        frame:Destroy()
    end

    self:Enable()
    return self
end

-- ============================================================
-- CONFIG SYSTEM (save/load using writefile/readfile if available)
-- ============================================================

local ConfigSystem = {}
ConfigSystem.__index = ConfigSystem

function ConfigSystem.new(opts)
    opts = opts or {}
    local folderName = opts.Folder or "AikeoHub"
    local configName = opts.Name or "default"

    local self = setmetatable({}, ConfigSystem)
    self._folder = folderName
    self._name = configName
    self._data = {}
    self._flags = {}

    -- Create folder if writefile available
    local ok = pcall(function()
        if not isfolder(folderName) then
            makefolder(folderName)
        end
    end)

    return self
end

function ConfigSystem:Register(flag, value)
    self._flags[flag] = value
    self._data[flag] = value
end

function ConfigSystem:Set(flag, value)
    self._data[flag] = value
end

function ConfigSystem:Get(flag)
    return self._data[flag]
end

function ConfigSystem:Save(name)
    name = name or self._name
    local path = self._folder .. "/" .. name .. ".json"
    local ok, err = pcall(function()
        local encoded = game:GetService("HttpService"):JSONEncode(self._data)
        writefile(path, encoded)
    end)
    return ok
end

function ConfigSystem:Load(name)
    name = name or self._name
    local path = self._folder .. "/" .. name .. ".json"
    local ok, result = pcall(function()
        if isfile(path) then
            local content = readfile(path)
            return game:GetService("HttpService"):JSONDecode(content)
        end
        return nil
    end)
    if ok and result then
        for k, v in pairs(result) do
            self._data[k] = v
        end
        return true
    end
    return false
end

function ConfigSystem:Delete(name)
    name = name or self._name
    local path = self._folder .. "/" .. name .. ".json"
    local ok = pcall(function()
        delfile(path)
    end)
    return ok
end

function ConfigSystem:ListConfigs()
    local configs = {}
    local ok = pcall(function()
        for _, file in pairs(listfiles(self._folder)) do
            local name = file:gsub(self._folder .. "/", ""):gsub(".json", "")
            table.insert(configs, name)
        end
    end)
    return configs
end

