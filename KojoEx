-- ============================================================
-- HIGHLIGHT PLAYERS (ESP via Highlight instance)
-- ============================================================

local HighlightESP = {}
HighlightESP.__index = HighlightESP

function HighlightESP.new(opts)
    opts = opts or {}
    local self = setmetatable({}, HighlightESP)
    self._enabled = false
    self._highlights = {}
    self._fillColor  = opts.FillColor or Color3.fromRGB(255, 75, 75)
    self._outlineColor = opts.OutlineColor or Color3.fromRGB(255, 255, 255)
    self._fillTrans  = opts.FillTransparency or 0.7
    self._conn = nil
    return self
end

function HighlightESP:Enable()
    if self._enabled then return end
    self._enabled = true

    local function AddHighlight(char)
        local h = Instance.new("Highlight")
        h.FillColor = self._fillColor
        h.OutlineColor = self._outlineColor
        h.FillTransparency = self._fillTrans
        h.Parent = char
        return h
    end

    for _, player in pairs(game.Players:GetPlayers()) do
        if player ~= game.Players.LocalPlayer and player.Character then
            self._highlights[player] = AddHighlight(player.Character)
        end
    end

    self._conn = game.Players.PlayerAdded:Connect(function(player)
        local function onChar(char)
            if self._enabled then
                self._highlights[player] = AddHighlight(char)
            end
        end
        player.CharacterAdded:Connect(onChar)
        if player.Character then onChar(player.Character) end
    end)
end

function HighlightESP:Disable()
    self._enabled = false
    if self._conn then
        self._conn:Disconnect()
        self._conn = nil
    end
    for _, h in pairs(self._highlights) do
        if h and h.Parent then
            h:Destroy()
        end
    end
    self._highlights = {}
end

function HighlightESP:SetFillColor(c)
    self._fillColor = c
    for _, h in pairs(self._highlights) do
        if h and h.Parent then h.FillColor = c end
    end
end

function HighlightESP:SetOutlineColor(c)
    self._outlineColor = c
    for _, h in pairs(self._highlights) do
        if h and h.Parent then h.OutlineColor = c end
    end
end

-- ============================================================
-- SILENT AIM (basic implementation)
-- ============================================================

local SilentAim = {}
SilentAim.__index = SilentAim

function SilentAim.new(opts)
    opts = opts or {}
    local self = setmetatable({}, SilentAim)
    self._enabled = false
    self._target = opts.Target or "Head"
    self._fov    = opts.FOV or 360
    self._teamCheck = opts.TeamCheck ~= false
    self._conn   = nil
    return self
end

function SilentAim:GetNearestPlayer()
    local localPlayer = game.Players.LocalPlayer
    local camera = workspace.CurrentCamera
    local viewCenter = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y / 2)
    local nearest, nearDist = nil, math.huge

    for _, player in pairs(game.Players:GetPlayers()) do
        if player ~= localPlayer then
            if self._teamCheck and player.Team == localPlayer.Team then
                continue
            end
            local char = player.Character
            if char then
                local targetPart = char:FindFirstChild(self._target) or char:FindFirstChild("HumanoidRootPart")
                if targetPart then
                    local screenPos, onScreen = camera:WorldToViewportPoint(targetPart.Position)
                    if onScreen then
                        local dist = Vector2.new(screenPos.X, screenPos.Y) - viewCenter
                        if dist.Magnitude < self._fov and dist.Magnitude < nearDist then
                            local hum = char:FindFirstChildOfClass("Humanoid")
                            if hum and hum.Health > 0 then
                                nearest = targetPart
                                nearDist = dist.Magnitude
                            end
                        end
                    end
                end
            end
        end
    end

    return nearest
end

function SilentAim:Enable()
    if self._enabled then return end
    self._enabled = true
end

function SilentAim:Disable()
    self._enabled = false
end

function SilentAim:SetFOV(fov)
    self._fov = fov
end

function SilentAim:SetTarget(target)
    self._target = target
end

