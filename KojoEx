--[[
    AikeoLib Extended Features Module
    Adds: TabBar (in-section tabs), RadioGroup, NumberInput, ProgressBar,
          TableView, SearchBar, Toggle Groups, Tooltip system,
          Config save/load, Watermark, FPS counter, Click Teleport,
          Drawing utilities, Anti-AFK, Speed Hack helpers, and more.
    
    Append this file or merge into AikeoLib.lua for full 4k+ line library.
    Usage: require(AikeoLib) then call Library.Extended features directly.
--]]

-- This file extends AikeoLib.lua with additional components and FPS utilities.
-- In usage, this is appended to the main AikeoLib.lua.

-- ============================================================
-- EXTENDED SECTION METHODS (mixed into sectionObj at creation)
-- ============================================================

-- These methods would be injected into the sectionObj prototype within AddSection.
-- Shown here as standalone documentation + extension pattern.

local ExtendedSection = {}

-- ====================================================
-- RADIO GROUP
-- A group of mutually exclusive options shown as pills
-- ====================================================
function ExtendedSection:AddRadioGroup(label, opts)
    opts = opts or {}
    local options   = opts.Options or { "Option 1", "Option 2" }
    local default   = opts.Default or options[1]
    local callback  = opts.Callback or function() end
    local disabled  = opts.Disabled ~= nil and opts.Disabled or false

    local value = default

    -- Row with label
    local container = Instance.new("Frame")
    container.BackgroundTransparency = 1
    container.Size = UDim2.new(1, 0, 0, 0)
    container.AutomaticSize = Enum.AutomaticSize.Y

    local labelEl = Instance.new("TextLabel")
    labelEl.Text = label
    labelEl.Font = Enum.Font.GothamMedium
    labelEl.TextSize = 12
    labelEl.TextColor3 = disabled and Color3.fromRGB(90, 88, 105) or Color3.fromRGB(225, 222, 238)
    labelEl.BackgroundTransparency = 1
    labelEl.Size = UDim2.new(1, -24, 0, 16)
    labelEl.Position = UDim2.new(0, 12, 0, 6)
    labelEl.TextXAlignment = Enum.TextXAlignment.Left
    labelEl.Parent = container

    -- Options row
    local optRow = Instance.new("Frame")
    optRow.BackgroundTransparency = 1
    optRow.Position = UDim2.new(0, 12, 0, 26)
    optRow.Size = UDim2.new(1, -24, 0, 26)
    optRow.Parent = container

    local listLayout = Instance.new("UIListLayout")
    listLayout.Padding = UDim.new(0, 6)
    listLayout.FillDirection = Enum.FillDirection.Horizontal
    listLayout.HorizontalAlignment = Enum.HorizontalAlignment.Left
    listLayout.SortOrder = Enum.SortOrder.LayoutOrder
    listLayout.Parent = optRow

    container.Size = UDim2.new(1, 0, 0, 58)

    local buttons = {}

    local function UpdateSelection(v)
        value = v
        for _, data in pairs(buttons) do
            local isSelected = data.value == v
            data.btn.BackgroundColor3 = isSelected
                and Color3.fromRGB(148, 100, 220)
                or Color3.fromRGB(38, 36, 50)
            data.btn.TextColor3 = isSelected
                and Color3.fromRGB(235, 230, 245)
                or Color3.fromRGB(155, 150, 175)
        end
        callback(v)
    end

    for i, opt in ipairs(options) do
        local btn = Instance.new("TextButton")
        btn.BackgroundColor3 = opt == value
            and Color3.fromRGB(148, 100, 220)
            or Color3.fromRGB(38, 36, 50)
        btn.Size = UDim2.new(0, 0, 1, 0)
        btn.AutomaticSize = Enum.AutomaticSize.X
        btn.Text = "  " .. opt .. "  "
        btn.Font = Enum.Font.GothamMedium
        btn.TextSize = 11
        btn.TextColor3 = opt == value
            and Color3.fromRGB(235, 230, 245)
            or Color3.fromRGB(155, 150, 175)
        btn.AutoButtonColor = false
        btn.LayoutOrder = i
        btn.Parent = optRow

        local corner = Instance.new("UICorner")
        corner.CornerRadius = UDim.new(0, 5)
        corner.Parent = btn

        if not disabled then
            btn.MouseButton1Click:Connect(function()
                UpdateSelection(opt)
            end)
        end

        table.insert(buttons, { btn = btn, value = opt })
    end

    return {
        Value = value,
        Set = function(self, v)
            UpdateSelection(v)
        end,
        GetValue = function(self)
            return value
        end,
        _frame = container,
    }
end

-- ====================================================
-- PROGRESS BAR (read-only display)
-- ====================================================
function ExtendedSection:AddProgressBar(label, opts)
    opts = opts or {}
    local min     = opts.Min or 0
    local max     = opts.Max or 100
    local default = opts.Default or 0
    local color   = opts.Color or Color3.fromRGB(148, 100, 220)
    local suffix  = opts.Suffix or "%"
    local height  = opts.Height or 8

    local value = default

    local container = Instance.new("Frame")
    container.BackgroundTransparency = 1
    container.Size = UDim2.new(1, 0, 0, 42)

    -- Label row
    local topRow = Instance.new("Frame")
    topRow.BackgroundTransparency = 1
    topRow.Position = UDim2.new(0, 12, 0, 4)
    topRow.Size = UDim2.new(1, -24, 0, 16)
    topRow.Parent = container

    local labelEl = Instance.new("TextLabel")
    labelEl.Text = label
    labelEl.Font = Enum.Font.GothamMedium
    labelEl.TextSize = 12
    labelEl.TextColor3 = Color3.fromRGB(225, 222, 238)
    labelEl.BackgroundTransparency = 1
    labelEl.Size = UDim2.new(1, -50, 1, 0)
    labelEl.TextXAlignment = Enum.TextXAlignment.Left
    labelEl.Parent = topRow

    local valLabel = Instance.new("TextLabel")
    valLabel.AnchorPoint = Vector2.new(1, 0)
    valLabel.Text = tostring(math.floor(value)) .. suffix
    valLabel.Font = Enum.Font.GothamMedium
    valLabel.TextSize = 12
    valLabel.TextColor3 = Color3.fromRGB(148, 100, 220)
    valLabel.BackgroundTransparency = 1
    valLabel.Position = UDim2.new(1, 0, 0, 0)
    valLabel.Size = UDim2.new(0, 48, 1, 0)
    valLabel.TextXAlignment = Enum.TextXAlignment.Right
    valLabel.Parent = topRow

    -- Bar
    local track = Instance.new("Frame")
    track.BackgroundColor3 = Color3.fromRGB(40, 38, 52)
    track.Position = UDim2.new(0, 12, 0, 24)
    track.Size = UDim2.new(1, -24, 0, height)
    track.Parent = container

    local trackCorner = Instance.new("UICorner")
    trackCorner.CornerRadius = UDim.new(0, height // 2)
    trackCorner.Parent = track

    local fill = Instance.new("Frame")
    fill.BackgroundColor3 = color
    local frac = (value - min) / math.max(1, max - min)
    fill.Size = UDim2.new(math.clamp(frac, 0, 1), 0, 1, 0)
    fill.Parent = track

    local fillCorner = Instance.new("UICorner")
    fillCorner.CornerRadius = UDim.new(0, height // 2)
    fillCorner.Parent = fill

    local function SetProgress(v)
        value = math.clamp(v, min, max)
        local f = (value - min) / math.max(1, max - min)
        fill.Size = UDim2.new(math.clamp(f, 0, 1), 0, 1, 0)
        valLabel.Text = tostring(math.floor(value)) .. suffix
    end

    return {
        Value = value,
        Set = function(self, v)
            SetProgress(v)
        end,
        _frame = container,
    }
end

-- ====================================================
-- TABLE VIEW (simple data table)
-- ====================================================
function ExtendedSection:AddTable(headers, rows, opts)
    opts = opts or {}
    local rowHeight = opts.RowHeight or 24
    local maxHeight = opts.MaxHeight or 120

    local container = Instance.new("Frame")
    container.BackgroundTransparency = 1
    container.Size = UDim2.new(1, 0, 0, 0)
    container.AutomaticSize = Enum.AutomaticSize.Y

    local scroll = Instance.new("ScrollingFrame")
    scroll.BackgroundColor3 = Color3.fromRGB(22, 22, 28)
    scroll.BorderSizePixel = 0
    scroll.Position = UDim2.new(0, 12, 0, 4)
    scroll.Size = UDim2.new(1, -24, 0, math.min(maxHeight, (#rows + 1) * rowHeight))
    scroll.ScrollBarThickness = 3
    scroll.ScrollBarImageColor3 = Color3.fromRGB(75, 70, 95)
    scroll.CanvasSize = UDim2.new(0, 0, 0, 0)
    scroll.AutomaticCanvasSize = Enum.AutomaticCanvasSize.Y
    scroll.Parent = container

    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 6)
    corner.Parent = scroll

    local stroke = Instance.new("UIStroke")
    stroke.Color = Color3.fromRGB(38, 38, 48)
    stroke.Thickness = 1
    stroke.Parent = scroll

    local layout = Instance.new("UIListLayout")
    layout.FillDirection = Enum.FillDirection.Vertical
    layout.SortOrder = Enum.SortOrder.LayoutOrder
    layout.Parent = scroll

    -- Header row
    local headerRow = Instance.new("Frame")
    headerRow.BackgroundColor3 = Color3.fromRGB(30, 28, 42)
    headerRow.Size = UDim2.new(1, 0, 0, rowHeight)
    headerRow.LayoutOrder = 0
    headerRow.Parent = scroll

    local headerList = Instance.new("UIListLayout")
    headerList.FillDirection = Enum.FillDirection.Horizontal
    headerList.SortOrder = Enum.SortOrder.LayoutOrder
    headerList.Parent = headerRow

    local colWidth = 1 / #headers
    for i, h in ipairs(headers) do
        local cell = Instance.new("TextLabel")
        cell.BackgroundTransparency = 1
        cell.Size = UDim2.new(colWidth, 0, 1, 0)
        cell.Text = "  " .. h
        cell.Font = Enum.Font.GothamSemibold
        cell.TextSize = 11
        cell.TextColor3 = Color3.fromRGB(148, 100, 220)
        cell.TextXAlignment = Enum.TextXAlignment.Left
        cell.LayoutOrder = i
        cell.Parent = headerRow
    end

    -- Data rows
    for ri, row in ipairs(rows) do
        local dataRow = Instance.new("Frame")
        dataRow.BackgroundColor3 = ri % 2 == 0
            and Color3.fromRGB(26, 24, 36)
            or Color3.fromRGB(22, 22, 28)
        dataRow.BackgroundTransparency = 0
        dataRow.Size = UDim2.new(1, 0, 0, rowHeight)
        dataRow.LayoutOrder = ri
        dataRow.Parent = scroll

        local rowList = Instance.new("UIListLayout")
        rowList.FillDirection = Enum.FillDirection.Horizontal
        rowList.SortOrder = Enum.SortOrder.LayoutOrder
        rowList.Parent = dataRow

        for ci, cell in ipairs(row) do
            local cellLabel = Instance.new("TextLabel")
            cellLabel.BackgroundTransparency = 1
            cellLabel.Size = UDim2.new(colWidth, 0, 1, 0)
            cellLabel.Text = "  " .. tostring(cell)
            cellLabel.Font = Enum.Font.GothamMedium
            cellLabel.TextSize = 11
            cellLabel.TextColor3 = Color3.fromRGB(200, 195, 215)
            cellLabel.TextXAlignment = Enum.TextXAlignment.Left
            cellLabel.LayoutOrder = ci
            cellLabel.Parent = dataRow
        end
    end

    container.Size = UDim2.new(1, 0, 0, scroll.Size.Y.Offset + 8)

    return {
        _scroll = scroll,
        _frame  = container,
        AddRow = function(self, row)
            local ri = #scroll:GetChildren() - 1 -- subtract layout
            local dataRow = Instance.new("Frame")
            dataRow.BackgroundColor3 = ri % 2 == 0
                and Color3.fromRGB(26, 24, 36)
                or Color3.fromRGB(22, 22, 28)
            dataRow.Size = UDim2.new(1, 0, 0, rowHeight)
            dataRow.LayoutOrder = ri
            dataRow.Parent = scroll

            local rowList = Instance.new("UIListLayout")
            rowList.FillDirection = Enum.FillDirection.Horizontal
            rowList.SortOrder = Enum.SortOrder.LayoutOrder
            rowList.Parent = dataRow

            for ci, cell in ipairs(row) do
                local cellLabel = Instance.new("TextLabel")
                cellLabel.BackgroundTransparency = 1
                cellLabel.Size = UDim2.new(colWidth, 0, 1, 0)
                cellLabel.Text = "  " .. tostring(cell)
                cellLabel.Font = Enum.Font.GothamMedium
                cellLabel.TextSize = 11
                cellLabel.TextColor3 = Color3.fromRGB(200, 195, 215)
                cellLabel.TextXAlignment = Enum.TextXAlignment.Left
                cellLabel.LayoutOrder = ci
                cellLabel.Parent = dataRow
            end
        end,
    }
end

-- ====================================================
-- SEARCH BOX (for filtered element lists)
-- ====================================================
function ExtendedSection:AddSearchBox(opts)
    opts = opts or {}
    local placeholder = opts.Placeholder or "Search..."
    local callback    = opts.Callback or function() end

    local container = Instance.new("Frame")
    container.BackgroundColor3 = Color3.fromRGB(30, 28, 40)
    container.Size = UDim2.new(1, 0, 0, 32)

    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 6)
    corner.Parent = container

    local stroke = Instance.new("UIStroke")
    stroke.Color = Color3.fromRGB(52, 50, 68)
    stroke.Thickness = 1
    stroke.Parent = container

    local padding = Instance.new("UIPadding")
    padding.PaddingLeft = UDim.new(0, 8)
    padding.PaddingRight = UDim.new(0, 8)
    padding.Parent = container

    local searchIcon = Instance.new("TextLabel")
    searchIcon.Text = "🔍"
    searchIcon.BackgroundTransparency = 1
    searchIcon.Position = UDim2.new(0, 8, 0.5, -8)
    searchIcon.Size = UDim2.new(0, 16, 0, 16)
    searchIcon.TextSize = 11
    searchIcon.Font = Enum.Font.GothamMedium
    searchIcon.TextColor3 = Color3.fromRGB(100, 95, 120)
    searchIcon.Parent = container

    local tb = Instance.new("TextBox")
    tb.BackgroundTransparency = 1
    tb.PlaceholderText = placeholder
    tb.PlaceholderColor3 = Color3.fromRGB(90, 88, 105)
    tb.Text = ""
    tb.Font = Enum.Font.GothamMedium
    tb.TextSize = 12
    tb.TextColor3 = Color3.fromRGB(225, 222, 238)
    tb.Position = UDim2.new(0, 28, 0, 0)
    tb.Size = UDim2.new(1, -28, 1, 0)
    tb.TextXAlignment = Enum.TextXAlignment.Left
    tb.ClearTextOnFocus = false
    tb.Parent = container

    tb.Focused:Connect(function()
        stroke.Color = Color3.fromRGB(148, 100, 220)
    end)
    tb.FocusLost:Connect(function()
        stroke.Color = Color3.fromRGB(52, 50, 68)
    end)
    tb:GetPropertyChangedSignal("Text"):Connect(function()
        callback(tb.Text)
    end)

    return {
        _frame = container,
        _tb    = tb,
        GetValue = function(self)
            return tb.Text
        end,
        Clear = function(self)
            tb.Text = ""
        end,
    }
end

-- ====================================================
-- IN-SECTION TABS (sub-navigation within a section)
-- ====================================================
function ExtendedSection:AddSubTabs(tabNames, callback)
    callback = callback or function() end
    local active = tabNames[1]

    local container = Instance.new("Frame")
    container.BackgroundTransparency = 1
    container.Size = UDim2.new(1, 0, 0, 30)

    local tabList = Instance.new("UIListLayout")
    tabList.Padding = UDim.new(0, 4)
    tabList.FillDirection = Enum.FillDirection.Horizontal
    tabList.HorizontalAlignment = Enum.HorizontalAlignment.Left
    tabList.SortOrder = Enum.SortOrder.LayoutOrder
    tabList.Parent = container

    local padding = Instance.new("UIPadding")
    padding.PaddingLeft = UDim.new(0, 12)
    padding.Parent = container

    local buttons = {}

    local function UpdateTabs(v)
        active = v
        for _, data in pairs(buttons) do
            local isActive = data.name == v
            data.btn.BackgroundColor3 = isActive
                and Color3.fromRGB(148, 100, 220)
                or Color3.fromRGB(32, 30, 42)
            data.btn.TextColor3 = isActive
                and Color3.fromRGB(235, 230, 245)
                or Color3.fromRGB(130, 125, 155)
            data.btn.BackgroundTransparency = isActive and 0 or 0
        end
        callback(v)
    end

    for i, name in ipairs(tabNames) do
        local btn = Instance.new("TextButton")
        btn.BackgroundColor3 = name == active
            and Color3.fromRGB(148, 100, 220)
            or Color3.fromRGB(32, 30, 42)
        btn.Size = UDim2.new(0, 0, 0, 22)
        btn.AutomaticSize = Enum.AutomaticSize.X
        btn.Text = "  " .. name .. "  "
        btn.Font = Enum.Font.GothamMedium
        btn.TextSize = 11
        btn.TextColor3 = name == active
            and Color3.fromRGB(235, 230, 245)
            or Color3.fromRGB(130, 125, 155)
        btn.AutoButtonColor = false
        btn.LayoutOrder = i
        btn.Parent = container

        local corner = Instance.new("UICorner")
        corner.CornerRadius = UDim.new(0, 5)
        corner.Parent = btn

        btn.MouseButton1Click:Connect(function()
            UpdateTabs(name)
        end)

        table.insert(buttons, { btn = btn, name = name })
    end

    return {
        Value = active,
        _frame = container,
        Set = function(self, v)
            UpdateTabs(v)
        end,
        GetValue = function(self)
            return active
        end,
    }
end

-- ====================================================
-- TOGGLE LOCK (FPS - toggle with cooldown)
-- ====================================================
function ExtendedSection:AddToggleLock(label, opts)
    opts = opts or {}
    local default   = opts.Default or false
    local cooldown  = opts.Cooldown or 0.5
    local callback  = opts.Callback or function() end
    local disabled  = opts.Disabled ~= nil and opts.Disabled or false

    local value = default
    local locked = false

    local row = Instance.new("Frame")
    row.BackgroundTransparency = 1
    row.Size = UDim2.new(1, 0, 0, 32)

    local padding = Instance.new("UIPadding")
    padding.PaddingLeft = UDim.new(0, 12)
    padding.PaddingRight = UDim.new(0, 12)
    padding.Parent = row

    local labelEl = Instance.new("TextLabel")
    labelEl.Text = label
    labelEl.Font = Enum.Font.GothamMedium
    labelEl.TextSize = 12
    labelEl.TextColor3 = disabled and Color3.fromRGB(90, 88, 105) or Color3.fromRGB(225, 222, 238)
    labelEl.BackgroundTransparency = 1
    labelEl.Size = UDim2.new(1, -52, 1, 0)
    labelEl.TextXAlignment = Enum.TextXAlignment.Left
    labelEl.Parent = row

    -- Indicator
    local indicator = Instance.new("TextLabel")
    indicator.AnchorPoint = Vector2.new(1, 0.5)
    indicator.BackgroundTransparency = 1
    indicator.Position = UDim2.new(1, 0, 0.5, 0)
    indicator.Size = UDim2.new(0, 48, 0, 14)
    indicator.Text = value and "ON" or "OFF"
    indicator.Font = Enum.Font.GothamBold
    indicator.TextSize = 10
    indicator.TextColor3 = value and Color3.fromRGB(148, 100, 220) or Color3.fromRGB(90, 88, 105)
    indicator.TextXAlignment = Enum.TextXAlignment.Right
    indicator.Parent = row

    local btn = Instance.new("TextButton")
    btn.BackgroundTransparency = 1
    btn.Size = UDim2.new(1, 0, 1, 0)
    btn.Text = ""
    btn.Parent = row

    local function Toggle(v)
        if locked then return end
        locked = true
        value = v
        indicator.Text = v and "ON" or "OFF"
        indicator.TextColor3 = v and Color3.fromRGB(148, 100, 220) or Color3.fromRGB(90, 88, 105)
        callback(v)
        task.delay(cooldown, function()
            locked = false
        end)
    end

    if not disabled then
        btn.MouseButton1Click:Connect(function()
            Toggle(not value)
        end)
    end

    return {
        Value = value,
        _frame = row,
        Set = function(self, v) Toggle(v) end,
        GetValue = function(self) return value end,
    }
end

